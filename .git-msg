# Archivo para commit automático
# Uso: .git-msg "tipo" "mensaje"
# Ejemplo: .git-msg "feat" "añadir formulario de contacto"

#!/bin/bash
# Hook de commit automático en español

TIPO=$1
MENSAJE=$2

if [ -z "$TIPO" ] || [ -z "$MENSAJE" ]; then
    echo "Uso: .git-msg 'tipo' 'mensaje'"
    echo "Tipos: feat, fix, docs, style, refactor, perf, test, chore"
    exit 1
fi

git add -A
git commit -m "$TIPO: $MENSAJE"