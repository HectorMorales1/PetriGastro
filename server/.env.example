PORT=3000
NODE_ENV=development

# Base de datos (usar DATABASE_URL o variables individuales)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=petrigastro_dev
DB_USER=postgres
DB_PASSWORD=your_password_here
# DATABASE_URL=postgresql://user:pass@host:5432/db

# JWT
JWT_SECRET=your_random_jwt_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Cliente
CLIENT_URL=http://localhost:5173

# Cloudinary (https://console.cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=petrigastro/platos

# SMTP (opcional - si no se configura usa Ethereal para desarrollo)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=tu_app_password
# SMTP_FROM=tu_correo@gmail.com
# SMTP_FROM_NAME=PetriGastro

# SSL/TLS (solo producción)
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem
# SSL_KEY_PATH=/etc/ssl/private/key.pem
# DB_CA_CERT=-----BEGIN CERTIFICATE-----\n...
